{
  "extends": "@tsconfig/recommended",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sap/cds": ["./node_modules/@cap-js/cds-types"],
      "#cds-models/*": ["./@cds-models/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "@cds-models"]
}
